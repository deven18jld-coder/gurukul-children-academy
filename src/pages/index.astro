    title: "Activity Room",
    description: "A vibrant space dedicated to arts, crafts, and creative expression to nurture imagination.",
    imageKey: "facilities/activity-room"
  },
  {
    title: "Library Corner",
    description: "A cozy reading environment stocked with age-appropriate books to foster a love for reading.",
    imageKey: "facilities/library"
  },
  {
    title: "Outdoor Play Area",
    description: "A safe, secure playground designed to build motor skills and encourage physical activity.",
    imageKey: "facilities/playground"
  },
  {
    title: "Safety & Security",
    description: "A fully secured campus with 24/7 CCTV surveillance and verified security personnel.",
    imageKey: "facilities/security"
  },
  {
    title: "Creative Spaces",
    description: "Specially designed areas that encourage collaborative learning and independent exploration.",
    imageKey: "facilities/creative-spaces"
  }
];

const galleryItems = [
  { id: "1", imageKey: "gallery/campus-life-1", alt: "Students learning" },
  { id: "2", imageKey: "gallery/campus-life-2", alt: "Outdoor activities" },
  { id: "3", imageKey: "gallery/campus-life-3", alt: "Art class" },
  { id: "4", imageKey: "gallery/campus-life-4", alt: "Sports day" },
  { id: "5", imageKey: "gallery/campus-life-5", alt: "Library time" },
  { id: "6", imageKey: "gallery/campus-life-6", alt: "Science experiment" }
];

const testimonialItems = [
  {
    parentName: "Priya Sharma",
    studentClass: "Nursery",
    quote: "Kiddies Academy has been a wonderful experience for our child. The teachers are so caring and the activities are always engaging. We've seen such a positive change in just a few months.",
    rating: 5
  },
  {
    parentName: "Rahul Verma",
    studentClass: "LKG",
    quote: "The focus on both academics and extracurriculars is exactly what we were looking for. The school's communication with parents is excellent, and the campus is incredibly safe.",
    rating: 5
  },
  {
