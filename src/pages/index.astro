---

<PageLayout 
  title="Kiddies Academy - Nursery & Primary School" 
  description="Playful. Safe. Premium. — The most loved school for ages 2–12."
>
  <Hero 
    title="Where Every Child's <span class='text-secondary'>Story Begins</span>"
    subtitle="Playful. Safe. Premium. — City's Most Loved School for Ages 2–12."
    primaryCtaLabel="Enquire for Admission"
    primaryCtaHref="/admissions"
    secondaryCtaLabel="Take a Virtual Tour"
    secondaryCtaHref="/gallery"
  />
  <TrustStrip items={trustItems} />
  <WhyChooseUs items={whyChooseUsItems} />
  <ProgramsPreview programs={programItems} />
  <FacilitiesPreview facilities={facilityItems} />
  <CampusLifePreview items={galleryItems} />
  <PrincipalMessage 
    name="Dr. Sarah Johnson"
    designation="Principal"
    message="Education is not just about imparting knowledge; it's about inspiring a lifelong love for learning. At Kiddies Academy, we strive to create an environment where every child feels valued, safe, and encouraged to explore their unique talents."
  />
  <TestimonialsPreview testimonials={testimonialItems} />
  <AdmissionsCTA />
</PageLayout>
