---
import PageLayout from '../layouts/PageLayout.astro';
import FacilitiesHero from '../components/sections/facilities/FacilitiesHero.astro';
import FacilitiesOverview from '../components/sections/facilities/FacilitiesOverview.astro';
import FacilityDetails from '../components/sections/facilities/FacilityDetails.astro';
import SafetySection from '../components/sections/facilities/SafetySection.astro';
import FacilitiesCTA from '../components/sections/facilities/FacilitiesCTA.astro';

const overviewItems = [
  { title: "Smart Classrooms", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>' },
  { title: "Library Corner", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>' },
  { title: "Activity Room", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>' },
  { title: "Play Area", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>' },
  { title: "Safe Campus", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' },
  { title: "Transport", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>' }
];

const facilitiesList = [
  {
    id: "smart-classrooms",
    title: "Smart, Interactive Classrooms",
    description: "Our classrooms are vibrant, well-lit spaces equipped with modern digital boards to make learning interactive and highly engaging. The furniture is ergonomically designed for children to ensure posture support and comfort.",
    highlights: [
      "Digital smart boards with interactive educational software",
      "Child-friendly, safe, and colorful ergonomic furniture",
      "Optimal natural lighting and cross-ventilation",
      "Low student-to-teacher ratio for personalized attention"
    ],
    imageFolder: "classrooms"
  },
  {
    id: "library",
    title: "The Reading Tree Library",
    description: "A magical corner filled with thousands of age-appropriate books. We encourage a love for reading from a very young age through interactive storytelling sessions and cozy reading nooks.",
    highlights: [
      "Extensive collection of picture books, phonics readers, and encyclopedias",
      "Comfortable floor seating and bean bags",
      "Weekly guided storytelling and drama sessions",
      "Lending program for Primary grade students"
    ],
    imageFolder: "library"
  },
  {
    id: "outdoor-play",
    title: "Expansive Outdoor Play Area",
    description: "Physical development is crucial in early years. Our secure outdoor playground features age-appropriate equipment, a sandpit, and open spaces for structured sports and free play.",
    highlights: [
      "Impact-absorbing rubberized flooring in play zones",
      "Dedicated sand and water play areas for sensory development",
      "Structured physical education classes by trained instructors",
      "Secure fencing with continuous staff supervision"
    ],
    imageFolder: "playground"
  }
];

const safetyFeatures = [
  {
    title: "24/7 CCTV Surveillance",
    description: "Comprehensive camera coverage across all classrooms, corridors, and play areas monitored by dedicated security personnel.",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>'
  },
  {
    title: "Restricted Campus Access",
    description: "Single-point entry system with strict visitor management. No unauthorized person is allowed inside the school premises without an <a href='/admissions' class='text-secondary hover:underline'>appointment</a>.",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>'
  },
  {
    title: "Background-Verified Staff",
    description: "100% of our teaching and support staff undergo rigorous background checks and police verification before employment.",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>'
  },
  {
    title: "GPS-Enabled Transport",
    description: "School buses are equipped with GPS tracking and female attendants. Parents can track the bus route in real-time.",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>'
  }
];
---

<PageLayout 
  title="Facilities - Kiddies Academy" 
  description="Explore our world-class facilities, smart classrooms, and secure campus designed for your child's holistic development."
>
  <FacilitiesHero />
  <FacilitiesOverview items={overviewItems} />
  <FacilityDetails facilities={facilitiesList} />
  <SafetySection features={safetyFeatures} />
  <FacilitiesCTA />
</PageLayout>
