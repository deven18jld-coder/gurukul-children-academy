---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import { getSchoolSchema, getWebsiteSchema, getBreadcrumbSchema } from '../utils/schema';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: any;
  showBreadcrumbs?: boolean;
}

const { 
  title, 
  description, 
  canonical, 
  ogImage, 
  schema,
  showBreadcrumbs = true 
} = Astro.props;

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const shouldRenderBreadcrumbs = showBreadcrumbs && !isHome;

// Build schema array
const breadcrumbItems = currentPath.split('/').filter(Boolean).map((segment, index, arr) => {
  const url = '/' + arr.slice(0, index + 1).join('/');
  const name = segment.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
  return { name, url };
});

const defaultSchema = [
  getSchoolSchema(),
  getWebsiteSchema()
];

if (shouldRenderBreadcrumbs) {
  defaultSchema.push(getBreadcrumbSchema(breadcrumbItems));
}

const finalSchema = schema || defaultSchema;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} schema={finalSchema}>
  <Header />
  <main>
    {shouldRenderBreadcrumbs && <Breadcrumbs currentPath={currentPath} />}
    <slot />
  </main>
  <Footer />
</BaseLayout>
