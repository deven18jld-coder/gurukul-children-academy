---
import Container from '../../ui/Container.astro';
import { contactData } from '../../../data/contact';
---

<section class="py-20 bg-primary relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-10">
    <div class="absolute top-[20%] left-[10%] w-[40%] h-[60%] bg-white rounded-full blur-[100px]"></div>
    <div class="absolute bottom-[10%] right-[10%] w-[30%] h-[80%] bg-accent rounded-full blur-[80px]"></div>
  </div>

  <Container class="relative z-10">
    <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-10 md:p-16 text-center max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-5xl font-nunito font-bold text-white mb-6">
        Ready to Take the Next Step?
      </h2>
      <p class="text-lg text-white/80 mb-10 max-w-2xl mx-auto">
        Join the Kiddies Academy family today. Reach out to our admissions team to secure your child's future.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6">
        <a href={contactData.phone.value} class="w-full sm:w-auto inline-flex items-center justify-center bg-white text-primary px-8 py-4 rounded-xl font-bold hover:bg-white/90 transition-all duration-300 shadow-xl shadow-black/10 hover:-translate-y-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call School
        </a>
        <a href={contactData.map.url} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center bg-transparent text-white border-2 border-white/20 px-8 py-4 rounded-xl font-bold hover:bg-white/10 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          Visit Campus
        </a>
      </div>
    </div>
  </Container>
</section>
