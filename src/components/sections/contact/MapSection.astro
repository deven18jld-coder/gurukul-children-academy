---
import Container from '../../ui/Container.astro';
import { contactData } from '../../../data/contact';
---

<section class="py-20 bg-white relative">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-nunito font-bold text-primary mb-4">
        Locate Us
      </h2>
      <p class="text-text/70 text-lg">
        We are conveniently located in the heart of the city, easily accessible from all major residential areas.
      </p>
    </div>

    <div class="w-full aspect-[16/9] md:aspect-[21/9] bg-soft-bg rounded-3xl overflow-hidden border border-primary/5 relative group">
      {contactData.map.iframeSrc ? (
        <iframe 
          src={contactData.map.iframeSrc} 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="w-full h-full"
        ></iframe>
      ) : (
        <div class="absolute inset-0 flex flex-col items-center justify-center bg-background group-hover:bg-soft-bg transition-colors duration-500">
          <div class="w-20 h-20 rounded-full bg-white flex items-center justify-center text-primary/30 mb-6 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="text-2xl font-nunito font-bold text-primary/40 mb-2">Interactive Map Placeholder</h3>
          <p class="text-text/40">Ready for Google Maps iframe integration.</p>
          
          <a href={contactData.map.url} target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex items-center text-primary font-bold hover:text-secondary transition-colors opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 duration-300">
            Open in Google Maps
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      )}
    </div>
  </Container>
</section>
