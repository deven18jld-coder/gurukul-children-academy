---
import Container from '../../ui/Container.astro';
import { contactData } from '../../../data/contact';
---

<section class="py-20 bg-soft-bg relative">
  <Container>
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-16">
      
      <div class="w-full lg:w-1/2">
        <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-6">
          Visit Our Campus
        </h2>
        <p class="text-text/80 text-lg leading-relaxed mb-10">
          The best way to understand our culture and environment is to see it firsthand. Our admissions office is open to welcome you.
        </p>
        
        <div class="bg-white rounded-3xl p-8 border border-primary/5 shadow-sm space-y-8">
          
          <div class="flex items-start gap-4">
            <div class="mt-1 text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-primary mb-2">School Address</h3>
              <p class="text-text/70 leading-relaxed">
                {contactData.address.street}<br />
                {contactData.address.city}, {contactData.address.state}<br />
                {contactData.address.pincode}
              </p>
            </div>
          </div>
          
          <div class="h-px w-full bg-primary/5"></div>
          
          <div class="flex items-start gap-4">
            <div class="mt-1 text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="w-full">
              <h3 class="font-bold text-primary mb-4">Operating Hours</h3>
              
              <div class="space-y-3">
                <div class="flex justify-between items-center text-sm">
                  <span class="text-text/70">Campus Operations</span>
                  <span class="font-bold text-text/90 text-right">{contactData.timings.campus}</span>
                </div>
                <div class="flex justify-between items-center text-sm">
                  <span class="text-text/70">School Office</span>
                  <span class="font-bold text-text/90 text-right">{contactData.timings.office}</span>
                </div>
                <div class="flex justify-between items-center text-sm">
                  <span class="text-text/70">Admissions Enquiry</span>
                  <span class="font-bold text-text/90 text-right">{contactData.timings.admissions}</span>
                </div>
              </div>
            </div>
          </div>
          
        </div>
      </div>
      
      <div class="w-full lg:w-1/2 flex flex-col justify-center">
        <!-- School Information Component goes here -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-primary text-white p-8 rounded-3xl">
            <div class="text-accent mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
            </div>
            <div class="text-sm font-bold text-white/60 uppercase tracking-widest mb-1">Board</div>
            <div class="text-xl font-nunito font-bold">{contactData.board}</div>
          </div>
          
          <div class="bg-white border border-primary/5 p-8 rounded-3xl shadow-sm">
            <div class="text-primary mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/><path d="M12 3a9 9 0 0 0 9 9H3a9 9 0 0 0 9-9Z"/></svg>
            </div>
            <div class="text-sm font-bold text-text/50 uppercase tracking-widest mb-1">Classes</div>
            <div class="text-xl font-nunito font-bold text-primary">{contactData.classesOffered}</div>
          </div>
          
          <div class="bg-white border border-primary/5 p-8 rounded-3xl shadow-sm sm:col-span-2">
            <div class="text-primary mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <div class="text-sm font-bold text-text/50 uppercase tracking-widest mb-1">Established</div>
            <div class="text-2xl font-nunito font-bold text-primary">{contactData.establishedYear}</div>
            <p class="text-sm text-text/60 mt-2">Delivering excellence in education for nearly a decade.</p>
          </div>
        </div>
      </div>
      
    </div>
  </Container>
</section>
