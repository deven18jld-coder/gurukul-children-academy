---
import Container from '../../ui/Container.astro';
import imageManifest from '../../../generated/image-manifest.json';

const manifest = imageManifest as Record<string, any>;
const heroContactImages = manifest?.hero?.contact?._files || [];
const autoImage = heroContactImages.length > 0 ? heroContactImages[0].src : undefined;

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "We Would Love to Hear From You", 
  subtitle = "Whether you have a question about admissions, fees, or just want to schedule a visit, our dedicated team is here to assist you."
} = Astro.props;

const finalImage = autoImage;
---

<section class="py-20 md:py-32 bg-primary relative overflow-hidden text-white">
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white rounded-full blur-[100px] translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-secondary rounded-full blur-[100px] -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <Container class="relative z-10">
    <div class="text-center max-w-4xl mx-auto flex flex-col items-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white text-sm font-bold mb-6 backdrop-blur-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Contact Us
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-nunito font-bold mb-6 leading-tight">
        {title}
      </h1>
      
      <p class="text-lg md:text-xl text-white/80 max-w-2xl font-medium leading-relaxed mb-12">
        {subtitle}
      </p>

      {finalImage && (
        <div class="w-full max-w-5xl mx-auto rounded-3xl overflow-hidden shadow-2xl border-4 border-white/20 mt-8 relative z-20">
          <img src={finalImage} alt="Contact" class="w-full h-auto max-h-[600px] object-cover" />
        </div>
      )}
    </div>
  </Container>
</section>
