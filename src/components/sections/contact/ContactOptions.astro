---
import Container from '../../ui/Container.astro';
import { contactData } from '../../../data/contact';

const options = [
  {
    title: "Call Us",
    value: contactData.phone.display,
    actionText: "Call Now",
    actionUrl: contactData.phone.value,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>'
  },
  {
    title: "WhatsApp",
    value: contactData.whatsapp.display,
    actionText: "Send Message",
    actionUrl: contactData.whatsapp.value,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/><path d="M14.05 2a9 9 0 0 1 8 7.94"/><path d="M14.05 6A5 5 0 0 1 18 10"/></svg>'
  },
  {
    title: "Email Us",
    value: contactData.email.display,
    actionText: "Send Email",
    actionUrl: contactData.email.value,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>'
  },
  {
    title: "Campus Visit",
    value: "Meet Admissions",
    actionText: "Schedule Visit",
    actionUrl: `${contactData.whatsapp.value}?text=${encodeURIComponent("Hello,\n\nI would like to schedule a campus visit for my child.\n\nPlease share available dates and timings.\n\nParent Name:\nChild Age:\nPreferred Visit Date:")}`,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>'
  }
];
---

<section class="py-16 bg-white relative -mt-10 z-20">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {options.map((option) => (
        <div class="bg-background rounded-3xl p-8 border border-primary/5 flex flex-col items-center text-center shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center text-primary mb-6 shadow-sm border border-primary/5">
            <Fragment set:html={option.icon} />
          </div>
          <h3 class="text-sm font-bold text-text/50 uppercase tracking-widest mb-2">
            {option.title}
          </h3>
          <p class="text-lg font-nunito font-bold text-primary mb-8 flex-grow">
            {option.value}
          </p>
          <a href={option.actionUrl} class="w-full inline-block bg-primary text-white font-bold py-3 px-6 rounded-xl hover:bg-primary/90 transition-colors">
            {option.actionText}
          </a>
        </div>
      ))}
    </div>
  </Container>
</section>
