---
import Container from '../ui/Container.astro';

interface Testimonial {
  parentName: string;
  studentClass: string;
  quote: string;
  rating: number; // 1 to 5
}

interface Props {
  title?: string;
  subtitle?: string;
  testimonials: Testimonial[];
}

const { 
  title = "Trusted by Parents", 
  subtitle = "Hear what our community has to say about their experience at Gurukul Children Academy.",
  testimonials 
} = Astro.props;

// Helper to render stars
const renderStars = (rating: number) => {
  const stars = [];
  for (let i = 1; i <= 5; i++) {
    if (i <= rating) {
      stars.push('<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>');
    } else {
      stars.push('<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent/30"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>');
    }
  }
  return stars.join('');
};
---

<section class="py-20 md:py-28 bg-soft-bg relative">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-4">
        {title}
      </h2>
      <p class="text-text/70 text-lg">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-3xl p-8 border border-white shadow-sm hover:shadow-xl transition-shadow duration-300 flex flex-col h-full relative">
          
          <div class="flex items-center gap-1 mb-6" set:html={renderStars(testimonial.rating)} />
          
          <p class="text-text/80 leading-relaxed font-medium flex-grow mb-8 relative">
            <span class="text-4xl text-soft-bg absolute -top-4 -left-3 -z-10 font-serif leading-none">"</span>
            {testimonial.quote}
          </p>
          
          <div class="flex items-center gap-4 mt-auto pt-6 border-t border-primary/5">
            <div class="w-12 h-12 rounded-full bg-background flex items-center justify-center text-primary font-bold">
              {testimonial.parentName.charAt(0)}
            </div>
            <div>
              <div class="font-nunito font-bold text-primary">{testimonial.parentName}</div>
              <div class="text-xs text-text/60 font-medium">Parent of {testimonial.studentClass} Student</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
