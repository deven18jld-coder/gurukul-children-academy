---
import Container from '../ui/Container.astro';

interface Props {
  title: string;
  subtitle: string;
  primaryCtaLabel: string;
  primaryCtaHref: string;
  secondaryCtaLabel: string;
  secondaryCtaHref: string;
  image?: string;
}

const {
  title,
  subtitle,
  primaryCtaLabel,
  primaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  image
} = Astro.props;

// Split title to highlight the last word or specific part if it contains a span or we can just accept HTML in title.
// To keep it safe, we'll assume the caller wraps the highlighted part in <span class="text-secondary">
---

<section class="relative bg-background overflow-hidden pt-16 md:pt-24 pb-16 md:pb-32">
  <Container>
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      
      <!-- Text Content -->
      <div class="w-full lg:w-1/2 flex flex-col items-center lg:items-start text-center lg:text-left z-10 animate-fade-in-up">
        
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-soft-bg text-secondary text-sm font-bold mb-6 border border-secondary/10">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
          Admissions Open 2025-26
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-nunito font-bold text-primary leading-tight mb-6" set:html={title} />
        
        <p class="text-lg md:text-xl text-text/80 mb-10 max-w-xl font-medium">
          {subtitle}
        </p>
        
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
          <a href={primaryCtaHref} class="w-full sm:w-auto text-center bg-primary text-white px-8 py-4 rounded-xl font-bold shadow-[0_4px_16px_rgba(18,48,74,0.15)] hover:shadow-[0_6px_24px_rgba(18,48,74,0.25)] hover:-translate-y-0.5 transition-all duration-300">
            {primaryCtaLabel}
          </a>
          <a href={secondaryCtaHref} class="w-full sm:w-auto text-center bg-white text-primary border border-primary/20 px-8 py-4 rounded-xl font-bold hover:bg-soft-bg hover:border-primary/40 transition-all duration-300">
            {secondaryCtaLabel}
          </a>
        </div>
      </div>
      
      <!-- Visual Content -->
      <div class="w-full lg:w-1/2 relative z-10">
        {image ? (
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border-4 border-white transform transition-transform hover:scale-[1.02] duration-500">
            <div class="absolute inset-0 bg-primary/10 mix-blend-multiply z-10 rounded-3xl pointer-events-none"></div>
            <img 
              src={image} 
              alt="Gurukul Children Academy - Premium School Environment" 
              class="w-full h-auto object-cover rounded-2xl aspect-[4/3] lg:aspect-auto lg:h-[500px]"
              loading="eager"
            />
          </div>
        ) : (
          <div class="w-full aspect-[4/3] lg:h-[500px] rounded-3xl bg-gradient-to-br from-soft-bg via-white to-background border border-primary/10 shadow-xl flex items-center justify-center relative overflow-hidden">
            <!-- Decorative shapes for empty state -->
            <div class="absolute top-10 right-10 w-32 h-32 bg-secondary/10 rounded-full blur-2xl"></div>
            <div class="absolute bottom-10 left-10 w-48 h-48 bg-accent/10 rounded-full blur-3xl"></div>
            <div class="text-primary/40 flex flex-col items-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-4"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
              <span class="font-nunito font-bold text-lg">Where Story Begins</span>
            </div>
          </div>
        )}

        <!-- Floating Decorative Element -->
        <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-2xl shadow-lg border border-primary/5 flex items-center gap-3 animate-bounce" style="animation-duration: 3s;">
          <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div>
            <div class="text-xs text-text/60 font-bold uppercase tracking-wider">Starting at</div>
            <div class="text-primary font-bold">Nursery</div>
          </div>
        </div>
      </div>
      
    </div>
  </Container>
  
  <!-- Subtle Background Pattern / Shape -->
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-[800px] h-[800px] bg-soft-bg rounded-full blur-3xl opacity-50 pointer-events-none z-0"></div>
</section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up, .animate-bounce, .animate-pulse {
      animation: none !important;
      transform: none !important;
    }
  }
</style>
