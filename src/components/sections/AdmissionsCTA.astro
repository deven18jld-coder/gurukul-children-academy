---
import Container from '../ui/Container.astro';

interface Props {
  title?: string;
  subtitle?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
}

const { 
  title = "Ready to Begin Your Child's Journey?", 
  subtitle = "Admissions are currently open for the 2025-26 academic year. Seats are filling up fast—take the first step today.",
  primaryCtaLabel = "Enquire Now",
  primaryCtaHref = "#admissions-form",
  secondaryCtaLabel = "Schedule a Visit",
  secondaryCtaHref = `https://wa.me/919876543210?text=${encodeURIComponent("Hello,\n\nI would like to schedule a campus visit for my child.\n\nPlease share available dates and timings.\n\nParent Name:\nChild Age:\nPreferred Visit Date:")}`
} = Astro.props;
---

<section class="py-20 md:py-28 relative overflow-hidden bg-primary text-white">
  <!-- Premium decorative background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[50%] -right-[10%] w-[70%] h-[200%] bg-white/5 rounded-full blur-3xl transform rotate-12"></div>
    <div class="absolute -bottom-[50%] -left-[10%] w-[50%] h-[150%] bg-secondary/20 rounded-full blur-3xl transform -rotate-12"></div>
  </div>

  <Container class="relative z-10">
    <div class="flex flex-col items-center text-center max-w-4xl mx-auto">
      
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent/20 text-accent font-bold text-sm mb-8 border border-accent/20 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        Admissions Open 2025-26
      </div>
      
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-nunito font-bold mb-6 leading-tight">
        {title}
      </h2>
      
      <p class="text-lg md:text-xl text-white/80 mb-10 max-w-2xl font-medium">
        {subtitle}
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
        <a href={primaryCtaHref} class="w-full sm:w-auto text-center bg-accent text-primary px-8 py-4 rounded-xl font-bold shadow-[0_4px_16px_rgba(214,166,90,0.3)] hover:shadow-[0_6px_24px_rgba(214,166,90,0.4)] hover:-translate-y-0.5 transition-all duration-300">
          {primaryCtaLabel}
        </a>
        <a href={secondaryCtaHref} class="w-full sm:w-auto text-center bg-white/10 text-white border border-white/20 px-8 py-4 rounded-xl font-bold hover:bg-white/20 transition-all duration-300 backdrop-blur-sm">
          {secondaryCtaLabel}
        </a>
      </div>
      
    </div>
  </Container>
</section>
