---
import Container from '../ui/Container.astro';
import imageManifest from '../../generated/image-manifest.json';

interface GalleryItem {
  id: string;
  imageKey: string;
  alt: string;
  colSpan?: boolean;
  rowSpan?: boolean;
}

interface Props {
  title?: string;
  subtitle?: string;
  items: GalleryItem[];
}

const { 
  title = "Life at Kiddies Academy", 
  subtitle = "A glimpse into the joy, curiosity, and friendship that fill our classrooms every day.",
  items 
} = Astro.props;

// Type helper for the manifest
const manifest = imageManifest as Record<string, any>;
---

<section class="py-20 md:py-28 bg-background relative overflow-hidden">
  <Container>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-4">
          {title}
        </h2>
        <p class="text-text/70 text-lg">
          {subtitle}
        </p>
      </div>
      <a href="/gallery" class="inline-flex items-center justify-center bg-white text-primary border border-primary/20 px-6 py-3 rounded-xl font-bold hover:bg-soft-bg hover:border-primary/40 transition-all duration-300 flex-shrink-0 group">
        View Full Gallery
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Masonry-style premium grid layout -->
    <div class="grid grid-cols-2 md:grid-cols-4 grid-rows-2 gap-3 md:gap-4 lg:gap-6 h-[600px] md:h-[500px] lg:h-[600px]">
      {items.slice(0, 6).map((item, index) => {
        const imagePath = manifest[item.imageKey];
        
        // Custom classes for masonry effect
        let itemClasses = "relative group rounded-2xl md:rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 bg-white border border-primary/5 cursor-pointer";
        
        // Dynamic spans to make the grid interesting
        if (index === 0) itemClasses += " col-span-2 row-span-2";
        else if (index === 3) itemClasses += " col-span-2 row-span-1";
        else itemClasses += " col-span-1 row-span-1";
        
        return (
          <div class={itemClasses}>
            {imagePath ? (
              <img 
                src={imagePath.src} 
                alt={item.alt} 
                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-soft-bg to-white group-hover:scale-105 transition-transform duration-700">
                <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMjAiIGN5PSIyMCIgcj0iMSIgZmlsbD0iIzEyMzA0QSIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+PC9zdmc+')] opacity-50"></div>
                <div class="text-primary/20 backdrop-blur-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
              </div>
            )}
            
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-primary/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <div class="bg-white text-primary rounded-full p-3 transform translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 delay-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </Container>
</section>
