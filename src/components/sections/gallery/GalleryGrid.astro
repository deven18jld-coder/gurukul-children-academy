---
import Container from '../../ui/Container.astro';
import imageManifest from '../../../generated/image-manifest.json';

// Define the shape we expect from the manifest
interface ImageFile {
  src: string;
  name: string;
  ext: string;
}

// Ensure the manifest is typed appropriately
const manifest = imageManifest as Record<string, any>;

// Extract gallery data dynamically
const galleryManifest = manifest.gallery || {};

// Format into a structured array
const categories = Object.keys(galleryManifest)
  .filter(key => key !== '_files') // Ignore root files if any, unless we want a "General" category
  .map(key => {
    const data = galleryManifest[key];
    const files: ImageFile[] = Array.isArray(data) ? data : (data._files || []);
    return {
      name: key.charAt(0).toUpperCase() + key.slice(1).replace(/-/g, ' '),
      slug: key,
      images: files
    };
  })
  .filter(cat => cat.images.length > 0);

// Fallback mock data if the gallery folder is completely empty
const displayCategories = categories.length > 0 ? categories : [
  { name: 'Classrooms', slug: 'classrooms', images: Array(4).fill(null) },
  { name: 'Activities', slug: 'activities', images: Array(6).fill(null) },
  { name: 'Events & Celebrations', slug: 'events', images: Array(3).fill(null) },
  { name: 'Sports', slug: 'sports', images: Array(5).fill(null) }
];
---

<section class="py-20 bg-background relative min-h-screen">
  <Container>
    {displayCategories.map((category) => (
      <div class="mb-20 last:mb-0">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-nunito font-bold text-primary">
            {category.name}
          </h2>
          <div class="text-sm font-bold text-text/50 bg-white px-3 py-1 rounded-full shadow-sm border border-primary/5">
            {category.images.length} Photos
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
          {category.images.map((img: ImageFile | null) => (
            <div class="aspect-square rounded-2xl overflow-hidden bg-soft-bg relative group shadow-sm border border-primary/5">
              {img ? (
                <img 
                  src={img.src} 
                  alt={img.alt || `${category.name} image`}
                  class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 ease-in-out"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-white to-soft-bg group-hover:scale-105 transition-transform duration-700">
                  <div class="text-primary/20 flex flex-col items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                    <span class="text-xs font-bold uppercase tracking-widest">Placeholder</span>
                  </div>
                </div>
              )}
              
              <!-- Hover Overlay -->
              <div class="absolute inset-0 bg-primary/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white transform translate-y-4 group-hover:translate-y-0 transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </Container>
</section>
