---
import Container from '../../ui/Container.astro';
import imageManifest from '../../../generated/image-manifest.json';

const manifest = imageManifest as Record<string, any>;
const heroGalleryImages = manifest?.hero?.gallery?._files || [];
const autoImage = heroGalleryImages.length > 0 ? heroGalleryImages[0].src : undefined;

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Our Gallery", 
  subtitle = "Take a glimpse into the vibrant daily life, joyous celebrations, and inspiring learning environments at Gurukul Children Academy."
} = Astro.props;

const finalImage = autoImage;
---

<section class="py-20 md:py-32 bg-primary relative overflow-hidden text-white">
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute -top-[20%] right-[10%] w-[50%] h-[100%] bg-white rounded-full blur-[120px]"></div>
    <div class="absolute bottom-[10%] -left-[10%] w-[40%] h-[80%] bg-secondary rounded-full blur-[100px]"></div>
  </div>

  <Container class="relative z-10">
    <div class="text-center max-w-4xl mx-auto flex flex-col items-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-nunito font-bold mb-6 leading-tight">
        {title}
      </h1>
      
      <p class="text-lg md:text-xl text-white/80 max-w-2xl font-medium leading-relaxed mb-12">
        {subtitle}
      </p>

      {finalImage && (
        <div class="w-full max-w-5xl mx-auto rounded-3xl overflow-hidden shadow-2xl border-4 border-white mt-8 relative z-20">
          <img src={finalImage} alt="Gallery" class="w-full h-auto max-h-[600px] object-cover" />
        </div>
      )}
    </div>
  </Container>
</section>
