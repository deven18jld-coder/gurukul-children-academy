---
import Container from '../../ui/Container.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "A Foundation for Lifelong Learning",
  description = "At Kiddies Academy, we don't just teach curriculum; we teach children how to learn. Our programs are carefully structured to transition smoothly from play-based exploration in early years to structured academic excellence in primary grades."
} = Astro.props;
---

<section class="py-16 bg-white border-b border-primary/5 relative z-20">
  <Container>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-nunito font-bold text-primary mb-6">
        {title}
      </h2>
      <p class="text-lg text-text/70 leading-relaxed">
        {description}
      </p>
    </div>
  </Container>
</section>
