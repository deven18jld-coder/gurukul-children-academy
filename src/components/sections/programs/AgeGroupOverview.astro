---
import Container from '../../ui/Container.astro';

interface Props {
  overview: string;
}

const { overview } = Astro.props;
---

<section class="py-16 md:py-24 bg-white border-b border-primary/5">
  <Container>
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row gap-8 md:gap-16 items-start">
      <div class="md:w-1/3">
        <h2 class="text-3xl font-nunito font-bold text-primary">
          Program Overview
        </h2>
        <div class="w-12 h-1 bg-accent mt-4 rounded-full"></div>
      </div>
      <div class="md:w-2/3">
        <p class="text-lg text-text/80 leading-relaxed font-medium">
          {overview}
        </p>
      </div>
    </div>
  </Container>
</section>
