---
import Container from '../../ui/Container.astro';
import { type RoutineItem } from '../../../data/programs';

interface Props {
  routine: RoutineItem[];
  themeColor: 'primary' | 'secondary' | 'accent';
}

const { routine, themeColor } = Astro.props;

const getDotColor = () => {
  switch (themeColor) {
    case 'secondary': return 'bg-secondary';
    case 'accent': return 'bg-accent';
    default: return 'bg-primary';
  }
};
---

<section class="py-20 bg-white border-t border-primary/5">
  <Container>
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-nunito font-bold text-primary mb-4">
          A Day in the Life
        </h2>
        <p class="text-text/70">A structured yet flexible routine to maximize learning and play.</p>
      </div>

      <div class="relative">
        <!-- Vertical Line -->
        <div class="absolute left-[15px] sm:left-1/2 top-4 bottom-4 w-1 bg-soft-bg sm:-translate-x-1/2 rounded-full"></div>
        
        <div class="space-y-8">
          {routine.map((item, index) => {
            const isEven = index % 2 === 0;
            return (
              <div class={`relative flex flex-col sm:flex-row items-start sm:items-center ${isEven ? 'sm:flex-row-reverse' : ''}`}>
                <!-- Center Dot -->
                <div class="absolute left-0 sm:left-1/2 w-8 h-8 rounded-full bg-white border-4 border-soft-bg flex items-center justify-center transform sm:-translate-x-1/2 z-10 mt-1 sm:mt-0 shadow-sm">
                  <div class={`w-2.5 h-2.5 rounded-full ${getDotColor()}`}></div>
                </div>
                
                <!-- Content -->
                <div class={`w-full sm:w-1/2 ${isEven ? 'sm:pl-12' : 'sm:pr-12 text-left sm:text-right'} pl-12 sm:pl-0`}>
                  <div class="inline-block px-3 py-1 bg-background rounded-full text-sm font-bold text-primary mb-2 border border-primary/5">
                    {item.time}
                  </div>
                  <h4 class="text-lg font-bold text-text/90">{item.activity}</h4>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </Container>
</section>
