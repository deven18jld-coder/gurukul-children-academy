---
import Container from '../../ui/Container.astro';

interface Props {
  name: string;
  ageRange: string;
  shortDescription: string;
  themeColor: 'primary' | 'secondary' | 'accent';
}

const { name, ageRange, shortDescription, themeColor } = Astro.props;

const getBgClass = () => {
  switch (themeColor) {
    case 'secondary': return 'bg-secondary';
    case 'accent': return 'bg-accent';
    default: return 'bg-primary';
  }
};
---

<section class={`py-20 md:py-32 relative overflow-hidden text-white ${getBgClass()}`}>
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white rounded-full blur-[100px] translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-black rounded-full blur-[100px] -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <Container class="relative z-10">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/20 border border-white/30 text-white text-sm font-bold mb-6 backdrop-blur-sm">
        Age {ageRange}
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-nunito font-bold mb-6 leading-tight">
        {name} Program
      </h1>
      
      <p class="text-lg md:text-xl text-white/90 font-medium leading-relaxed">
        {shortDescription}
      </p>
    </div>
  </Container>
</section>
