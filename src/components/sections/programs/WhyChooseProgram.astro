---
import Container from '../../ui/Container.astro';

interface Props {
  text: string;
}

const { text } = Astro.props;
---

<section class="py-20 bg-primary text-white relative">
  <Container>
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-10">
      
      <div class="w-24 h-24 md:w-32 md:h-32 flex-shrink-0 bg-white/10 rounded-full flex items-center justify-center text-accent backdrop-blur-sm border border-white/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      </div>
      
      <div>
        <h2 class="text-2xl md:text-3xl font-nunito font-bold mb-4">
          Why Parents Choose Us
        </h2>
        <p class="text-lg text-white/80 leading-relaxed font-medium">
          "{text}"
        </p>
      </div>
      
    </div>
  </Container>
</section>
