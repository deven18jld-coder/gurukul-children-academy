---
import Container from '../../ui/Container.astro';

interface PhilosophyItem {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  title?: string;
  items: PhilosophyItem[];
}

const { 
  title = "Our Learning Philosophy",
  items 
} = Astro.props;
---

<section class="py-20 md:py-28 bg-primary text-white relative">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-nunito font-bold mb-4">
        {title}
      </h2>
      <div class="w-16 h-1 bg-secondary mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {items.map((item) => (
        <div class="flex flex-col items-center text-center">
          <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center text-accent mb-6 border border-white/20 backdrop-blur-sm">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="text-2xl font-nunito font-bold mb-4">{item.title}</h3>
          <p class="text-white/70 leading-relaxed" set:html={item.description} />
        </div>
      ))}
    </div>
  </Container>
</section>
