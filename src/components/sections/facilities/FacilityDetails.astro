---
import Container from '../../ui/Container.astro';
import imageManifest from '../../../generated/image-manifest.json';

interface Facility {
  id: string;
  title: string;
  description: string;
  highlights: string[];
  imageFolder: string;
}

interface Props {
  facilities: Facility[];
}

const { facilities } = Astro.props;
const manifest = imageManifest as Record<string, any>;
---

<section class="py-20 md:py-32 bg-background relative">
  <Container>
    <div class="space-y-24">
      {facilities.map((facility, index) => {
        const isEven = index % 2 === 0;
        
        // Dynamically grab the first image from the specified folder in the manifest
        let imageSrc = null;
        let imageAlt = facility.title;
        if (manifest.facilities && manifest.facilities[facility.imageFolder]) {
          const folderData = manifest.facilities[facility.imageFolder];
          const files = Array.isArray(folderData) ? folderData : (folderData._files || []);
          if (files.length > 0) {
            imageSrc = files[0].src;
            imageAlt = files[0].alt || facility.title;
          }
        }

        return (
          <div class={`flex flex-col lg:flex-row gap-12 lg:gap-20 items-center ${isEven ? '' : 'lg:flex-row-reverse'}`} id={facility.id}>
            
            {/* Visual Side */}
            <div class="w-full lg:w-1/2 relative">
              <div class={`absolute inset-0 bg-soft-bg rounded-3xl -z-10 transform ${isEven ? '-rotate-3 translate-x-4' : 'rotate-3 -translate-x-4'} scale-105`}></div>
              
              <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-white border border-primary/5 shadow-xl relative group">
                {imageSrc ? (
                  <img 
                    src={imageSrc} 
                    alt={imageAlt} 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-soft-bg to-white group-hover:scale-105 transition-transform duration-700">
                    <div class="text-primary/20 flex flex-col items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-4"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                      <span class="text-sm font-bold uppercase tracking-widest text-primary/30">Facility Image Placeholder</span>
                    </div>
                  </div>
                )}
              </div>
            </div>
            
            {/* Content Side */}
            <div class="w-full lg:w-1/2">
              <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-6">
                {facility.title}
              </h2>
              <p class="text-lg text-text/80 leading-relaxed mb-8">
                {facility.description}
              </p>
              
              <ul class="space-y-4">
                {facility.highlights.map(highlight => (
                  <li class="flex items-start">
                    <span class="mt-1 mr-3 text-secondary flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </span>
                    <span class="text-text/90 font-medium">{highlight}</span>
                  </li>
                ))}
              </ul>
            </div>
            
          </div>
        );
      })}
    </div>
  </Container>
</section>
