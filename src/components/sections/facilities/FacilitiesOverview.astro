---
import Container from '../../ui/Container.astro';

interface OverviewItem {
  title: string;
  icon: string;
}

interface Props {
  items: OverviewItem[];
}

const { items } = Astro.props;
---

<section class="py-16 bg-white relative z-20 border-b border-primary/5">
  <Container>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {items.map((item) => (
        <div class="flex flex-col items-center text-center p-6 bg-background rounded-2xl border border-primary/5 hover:border-secondary/30 hover:bg-soft-bg transition-colors group">
          <div class="text-primary mb-3 group-hover:text-secondary transition-colors">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="text-sm font-bold text-text/80">{item.title}</h3>
        </div>
      ))}
    </div>
  </Container>
</section>
