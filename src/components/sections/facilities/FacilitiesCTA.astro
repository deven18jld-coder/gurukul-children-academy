---
import Container from '../../ui/Container.astro';
---

<section class="py-20 bg-soft-bg relative border-t border-primary/5">
  <Container>
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl font-nunito font-bold text-primary mb-6">
        See It to Believe It
      </h2>
      <p class="text-lg text-text/70 mb-10">
        The best way to understand the Kiddies Academy difference is to walk our halls. Schedule a personal tour of our facilities today.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/admissions" class="w-full sm:w-auto inline-flex items-center justify-center bg-primary text-white px-8 py-4 rounded-xl font-bold hover:bg-primary/90 transition-all duration-300 shadow-md">
          Schedule a Tour
        </a>
        <a href="/admissions#process" class="w-full sm:w-auto inline-flex items-center justify-center bg-white text-primary border border-primary/20 px-8 py-4 rounded-xl font-bold hover:bg-primary/5 transition-all duration-300 shadow-sm">
          Admission Process
        </a>
      </div>
    </div>
  </Container>
</section>
