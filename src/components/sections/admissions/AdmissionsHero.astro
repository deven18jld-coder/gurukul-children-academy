---
import Container from '../../ui/Container.astro';
import imageManifest from '../../../generated/image-manifest.json';

const manifest = imageManifest as Record<string, any>;
const heroAdmissionsImages = manifest?.hero?.admissions?._files || [];
const autoImage = heroAdmissionsImages.length > 0 ? heroAdmissionsImages[0].src : undefined;

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Join the Gurukul Children Academy Family", 
  subtitle = "We are thrilled that you are considering Gurukul Children Academy for your child's educational journey. Discover our simple, transparent admissions process."
} = Astro.props;

const finalImage = autoImage;
---

<section class="py-20 md:py-32 bg-primary relative overflow-hidden text-white">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute -top-[20%] right-[10%] w-[50%] h-[100%] bg-white rounded-full blur-[120px]"></div>
    <div class="absolute bottom-[10%] -left-[10%] w-[40%] h-[80%] bg-secondary rounded-full blur-[100px]"></div>
  </div>

  <Container class="relative z-10">
    <div class="text-center max-w-4xl mx-auto flex flex-col items-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white text-sm font-bold mb-6 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        Admissions 2025-26
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-nunito font-bold mb-8 leading-tight">
        {title}
      </h1>
      
      <p class="text-lg md:text-xl text-white/80 max-w-2xl font-medium leading-relaxed mb-12">
        {subtitle}
      </p>

      {finalImage && (
        <div class="w-full max-w-5xl mx-auto rounded-3xl overflow-hidden shadow-2xl border-4 border-white/20 mt-8 relative z-20">
          <img src={finalImage} alt="Admissions" class="w-full h-auto max-h-[600px] object-cover" />
        </div>
      )}
    </div>
  </Container>
</section>
