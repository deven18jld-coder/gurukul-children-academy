---
import Container from '../../ui/Container.astro';

interface Document {
  title: string;
  description?: string;
  required: boolean;
}

interface Props {
  title?: string;
  subtitle?: string;
  documents: Document[];
}

const { 
  title = "Required Documents",
  subtitle = "Please keep clear photocopies of the following documents ready for the enrollment process.",
  documents
} = Astro.props;
---

<section class="py-20 bg-white relative">
  <Container>
    <div class="flex flex-col md:flex-row gap-12 lg:gap-20">
      
      <div class="w-full md:w-5/12 lg:w-4/12">
        <div class="sticky top-24">
          <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-6">
            {title}
          </h2>
          <p class="text-text/70 text-lg mb-8 leading-relaxed">
            {subtitle}
          </p>
          <div class="bg-soft-bg p-6 rounded-2xl border border-primary/5">
            <h4 class="font-bold text-primary mb-2 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Note
            </h4>
            <p class="text-sm text-text/80 leading-relaxed">
              Original documents will be required for verification during the final admission process. They will be returned immediately after verification.
            </p>
          </div>
        </div>
      </div>
      
      <div class="w-full md:w-7/12 lg:w-8/12">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
          {documents.map((doc) => (
            <div class="bg-background rounded-2xl p-6 border border-primary/5 flex items-start gap-4 hover:border-secondary/30 transition-colors">
              <div class="mt-1 text-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-primary mb-1 pr-16 relative">
                  {doc.title}
                  {doc.required ? (
                    <span class="absolute right-0 top-0 text-[10px] font-bold uppercase tracking-wider bg-accent/20 text-accent px-2 py-0.5 rounded">Required</span>
                  ) : (
                    <span class="absolute right-0 top-0 text-[10px] font-bold uppercase tracking-wider bg-black/5 text-text/50 px-2 py-0.5 rounded">Optional</span>
                  )}
                </h3>
                {doc.description && (
                  <p class="text-sm text-text/60 leading-relaxed mt-2">{doc.description}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
      
    </div>
  </Container>
</section>
