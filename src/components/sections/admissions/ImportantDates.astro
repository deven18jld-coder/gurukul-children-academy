---
import Container from '../../ui/Container.astro';

interface EventDate {
  date: string;
  title: string;
  description?: string;
  isPast?: boolean;
}

interface Props {
  title?: string;
  dates: EventDate[];
}

const { 
  title = "Important Dates",
  dates
} = Astro.props;
---

<section class="py-20 bg-background relative border-t border-primary/5">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-4">
        {title}
      </h2>
    </div>

    <div class="max-w-4xl mx-auto bg-white rounded-3xl p-6 md:p-10 shadow-sm border border-primary/5">
      <div class="space-y-6 md:space-y-0 md:divide-y divide-primary/5">
        {dates.map((date) => (
          <div class={`flex flex-col md:flex-row md:items-center py-4 md:py-6 gap-2 md:gap-8 ${date.isPast ? 'opacity-50 grayscale' : ''}`}>
            
            <div class="md:w-1/3 flex-shrink-0">
              <div class="font-bold text-secondary text-lg flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {date.date}
              </div>
            </div>
            
            <div class="md:w-2/3">
              <h3 class="text-xl font-nunito font-bold text-primary mb-1">
                {date.title}
                {date.isPast && <span class="ml-3 text-xs font-bold uppercase tracking-wider bg-gray-100 text-gray-500 px-2 py-1 rounded">Passed</span>}
              </h3>
              {date.description && (
                <p class="text-text/70 text-sm">{date.description}</p>
              )}
            </div>
            
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>
