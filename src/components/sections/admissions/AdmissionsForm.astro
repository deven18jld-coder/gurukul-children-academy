---
import Container from '../../ui/Container.astro';

const programs = [
  "Playgroup (2-3 years)",
  "Nursery (3-4 years)",
  "LKG (4-5 years)",
  "UKG (5-6 years)",
  "Primary (Grades 1-5)"
];
---

<section id="admissions-form" class="py-20 md:py-32 relative bg-white">
  <Container>
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-nunito font-bold text-gray-900 mb-6">
          Admission Enquiry Form
        </h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto">
          Please fill out the form below to register your interest. Our admissions team will get back to you shortly to guide you through the next steps.
        </p>
      </div>

      <div class="bg-soft-bg rounded-3xl p-8 md:p-12 shadow-sm border border-gray-100 relative overflow-hidden">
        
        <!-- Success State (Hidden by default) -->
        <div id="form-success" class="hidden absolute inset-0 bg-soft-bg flex flex-col items-center justify-center z-10 p-8 text-center">
          <div class="w-20 h-20 bg-green-100 text-green-500 rounded-full flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="text-3xl font-nunito font-bold text-gray-900 mb-4">Thank You!</h3>
          <p class="text-lg text-gray-700 mb-8 max-w-md mx-auto">
            Your admission enquiry has been successfully submitted. Our team will contact you within 24 hours.
          </p>
          <button id="reset-form" class="bg-primary text-white px-8 py-3 rounded-xl font-bold hover:bg-primary/90 transition-colors duration-300">
            Submit Another Enquiry
          </button>
        </div>

        <!-- Form -->
        <form id="admission-enquiry-form" class="space-y-6">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="parentName" class="block text-sm font-bold text-gray-700">Parent/Guardian Name *</label>
              <input type="text" id="parentName" name="parentName" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white" placeholder="Enter full name">
            </div>
            
            <div class="space-y-2">
              <label for="childName" class="block text-sm font-bold text-gray-700">Child's Name *</label>
              <input type="text" id="childName" name="childName" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white" placeholder="Enter child's full name">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="childAge" class="block text-sm font-bold text-gray-700">Child's Age (in years) *</label>
              <input type="number" id="childAge" name="childAge" min="1" max="15" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white" placeholder="E.g. 4">
            </div>
            
            <div class="space-y-2">
              <label for="programme" class="block text-sm font-bold text-gray-700">Programme Interested In *</label>
              <select id="programme" name="programme" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white appearance-none">
                <option value="" disabled selected>Select a programme</option>
                {programs.map(prog => (
                  <option value={prog}>{prog}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="mobile" class="block text-sm font-bold text-gray-700">Mobile Number *</label>
              <input type="tel" id="mobile" name="mobile" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white" placeholder="Enter mobile number">
            </div>
            
            <div class="space-y-2">
              <label for="email" class="block text-sm font-bold text-gray-700">Email Address *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white" placeholder="Enter email address">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="visitDate" class="block text-sm font-bold text-gray-700">Preferred Visit Date (Optional)</label>
              <input type="date" id="visitDate" name="visitDate" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white">
            </div>
            
            <div class="space-y-2">
              <label for="callbackTime" class="block text-sm font-bold text-gray-700">Preferred Callback Time (Optional)</label>
              <select id="callbackTime" name="callbackTime" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white appearance-none">
                <option value="" selected>Any time</option>
                <option value="morning">Morning (9 AM - 12 PM)</option>
                <option value="afternoon">Afternoon (12 PM - 3 PM)</option>
                <option value="evening">Evening (3 PM - 6 PM)</option>
              </select>
            </div>
          </div>

          <div class="space-y-2">
            <label for="message" class="block text-sm font-bold text-gray-700">Additional Notes / Message *</label>
            <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-white resize-none" placeholder="How can we help you?"></textarea>
          </div>

          <div class="pt-4 text-center">
            <button type="submit" class="w-full sm:w-auto px-10 py-4 bg-primary text-white rounded-xl font-bold text-lg hover:bg-primary/90 transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-1 inline-flex justify-center items-center gap-2">
              Submit Enquiry
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </div>

        </form>
      </div>
    </div>
  </Container>
</section>

<script>
  const form = document.getElementById('admission-enquiry-form') as HTMLFormElement;
  const successState = document.getElementById('form-success');
  const resetBtn = document.getElementById('reset-form');

  if (form && successState && resetBtn) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Simulate form submission
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerHTML;
      
      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Submitting...';
      submitBtn.classList.add('opacity-70');
      
      setTimeout(() => {
        form.classList.add('hidden');
        successState.classList.remove('hidden');
        
        // Reset button state
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
        submitBtn.classList.remove('opacity-70');
      }, 800);
    });

    resetBtn.addEventListener('click', () => {
      form.reset();
      successState.classList.add('hidden');
      form.classList.remove('hidden');
    });
  }
</script>
