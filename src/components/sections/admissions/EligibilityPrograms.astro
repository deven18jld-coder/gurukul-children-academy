---
import Container from '../../ui/Container.astro';

interface ProgramEligibility {
  name: string;
  ageRange: string;
  cutOffDate: string;
  summary: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  programs: ProgramEligibility[];
}

const { 
  title = "Eligibility & Programs",
  subtitle = "Find the right starting point for your child based on their age.",
  programs
} = Astro.props;
---

<section class="py-20 bg-white relative">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-4">
        {title}
      </h2>
      <p class="text-text/70 text-lg">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {programs.map((program, index) => (
        <div class="bg-background rounded-3xl p-8 border border-primary/5 shadow-sm hover:shadow-xl transition-shadow duration-300 relative overflow-hidden group">
          
          <div class="absolute top-0 left-0 w-full h-1 bg-secondary group-hover:h-2 transition-all duration-300"></div>
          
          <h3 class="text-2xl font-nunito font-bold text-primary mb-4 mt-2">
            {program.name}
          </h3>
          
          <div class="flex items-center gap-2 mb-2 text-primary font-bold bg-white px-4 py-2 rounded-xl border border-primary/5 shadow-sm w-max">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Age {program.ageRange}
          </div>
          
          <div class="text-xs text-text/50 font-medium mb-6 px-1">
            Must be {program.ageRange.split('–')[0]} by {program.cutOffDate}
          </div>
          
          <p class="text-text/80 leading-relaxed">
            {program.summary}
          </p>
          
        </div>
      ))}
    </div>
  </Container>
</section>
