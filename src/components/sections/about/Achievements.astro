---
import Container from '../../ui/Container.astro';

interface Achievement {
  title: string;
  value: string;
  description: string;
}

interface Props {
  title?: string;
  items: Achievement[];
}

const { 
  title = "Our Pride & Recognition",
  items
} = Astro.props;
---

<section class="py-20 bg-primary relative text-white border-t border-white/10">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-nunito font-bold mb-4">
        {title}
      </h2>
      <div class="w-16 h-1 bg-secondary mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {items.map((item) => (
        <div class="bg-white/5 backdrop-blur-sm rounded-3xl p-8 border border-white/10 text-center hover:bg-white/10 hover:-translate-y-1 transition-all duration-300">
          <div class="text-4xl md:text-5xl font-nunito font-bold text-accent mb-4">
            {item.value}
          </div>
          <h3 class="text-lg font-bold text-white mb-2">
            {item.title}
          </h3>
          <p class="text-white/70 text-sm">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </Container>
</section>
