---
import Container from '../../ui/Container.astro';
import imageManifest from '../../../generated/image-manifest.json';

interface Teacher {
  name: string;
  role: string;
  qualification: string;
  imageKey?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  teachers: Teacher[];
}

const { 
  title = "Meet Our Inspiring Educators",
  subtitle = "Our dedicated team of professionals brings passion, experience, and care to every classroom.",
  teachers: fallbackTeachers
} = Astro.props;

// Type helper for the manifest
const manifest = imageManifest as Record<string, any>;
const teacherFiles = manifest?.teachers?._files || [];

const displayTeachers = teacherFiles.length > 0 
  ? teacherFiles.map((file: any) => {
      let displayName = file.alt || file.name;
      
      // Use generic fallback for names that look like generic image files or random strings
      if (/^(img|dsc|image|photo|unt|scan|pic)[\-_]?\d+/i.test(displayName) || /^[\w\d]{8,}/.test(displayName) || /\d{4}/.test(displayName) || displayName.toLowerCase() === 'random-file-name') {
        displayName = "Faculty Member";
      } else {
        // Format names nicely (e.g., "rakesh-singh" -> "Rakesh Singh")
        displayName = displayName.replace(/[-_]/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase());
      }
      
      return {
        name: displayName,
        role: "Educator",
        qualification: "",
        imageSrc: file.src
      };
    })
  : fallbackTeachers;
---

<section class="py-20 md:py-28 bg-soft-bg relative">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-4">
        {title}
      </h2>
      <p class="text-text/70 text-lg">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {displayTeachers.map((teacher: any) => {
        const imagePath = teacher.imageSrc || (teacher.imageKey ? manifest[teacher.imageKey]?.src : undefined);
        
        return (
          <div class="bg-white rounded-3xl overflow-hidden border border-primary/5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
            
            <div class="aspect-[4/5] relative bg-background overflow-hidden border-b border-primary/5">
              {imagePath ? (
                <img 
                  src={imagePath} 
                  alt={teacher.name} 
                  class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-background to-soft-bg group-hover:scale-105 transition-transform duration-700">
                  <div class="w-20 h-20 rounded-full bg-white/60 flex items-center justify-center text-primary/20 backdrop-blur-sm shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  </div>
                </div>
              )}
            </div>
            
            <div class="p-6 text-center">
              <h3 class="font-nunito font-bold text-xl text-primary mb-1 group-hover:text-secondary transition-colors">
                {teacher.name}
              </h3>
              <div class="text-secondary font-medium text-sm mb-2">{teacher.role}</div>
              <p class="text-text/60 text-xs uppercase tracking-wide font-bold">
                {teacher.qualification}
              </p>
            </div>
            
          </div>
        );
      })}
    </div>
  </Container>
</section>
