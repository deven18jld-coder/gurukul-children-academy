---
import Container from '../../ui/Container.astro';

interface Props {
  visionTitle?: string;
  visionText: string;
  missionTitle?: string;
  missionText: string;
}

const { 
  visionTitle = "Our Vision",
  visionText,
  missionTitle = "Our Mission",
  missionText
} = Astro.props;
---

<section class="py-20 md:py-28 bg-primary relative text-white overflow-hidden">
  <!-- Subtle decorative background -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white rounded-full blur-[100px] translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-secondary rounded-full blur-[100px] -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <Container class="relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      
      <!-- Vision Card -->
      <div class="bg-white/5 backdrop-blur-sm rounded-3xl p-10 md:p-14 border border-white/10 hover:bg-white/10 transition-colors duration-300 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 text-white/5 transform group-hover:scale-110 transition-transform duration-500 pointer-events-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        </div>
        
        <div class="w-16 h-16 rounded-2xl bg-accent/20 flex items-center justify-center text-accent mb-8 shadow-inner border border-accent/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h4l3-9 5 18 3-9h5"/></svg>
        </div>
        
        <h2 class="text-3xl font-nunito font-bold mb-6 text-white">{visionTitle}</h2>
        <p class="text-white/80 text-lg leading-relaxed font-medium">
          {visionText}
        </p>
      </div>
      
      <!-- Mission Card -->
      <div class="bg-white/5 backdrop-blur-sm rounded-3xl p-10 md:p-14 border border-white/10 hover:bg-white/10 transition-colors duration-300 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 text-white/5 transform group-hover:scale-110 transition-transform duration-500 pointer-events-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>
        </div>
        
        <div class="w-16 h-16 rounded-2xl bg-secondary/30 flex items-center justify-center text-secondary mb-8 shadow-inner border border-secondary/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2v20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
        </div>
        
        <h2 class="text-3xl font-nunito font-bold mb-6 text-white">{missionTitle}</h2>
        <p class="text-white/80 text-lg leading-relaxed font-medium">
          {missionText}
        </p>
      </div>
      
    </div>
  </Container>
</section>
