---
import Container from '../../ui/Container.astro';

interface ValueItem {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  items: ValueItem[];
}

const { 
  title = "Our Core Values",
  subtitle = "The principles that guide our educators, inspire our students, and shape our community.",
  items
} = Astro.props;
---

<section class="py-20 md:py-28 bg-background relative">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-4">
        {title}
      </h2>
      <p class="text-text/70 text-lg">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {items.map((item) => (
        <div class="bg-white rounded-3xl p-8 border border-primary/5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col items-center text-center group">
          <div class="w-16 h-16 rounded-full bg-soft-bg flex items-center justify-center text-primary mb-6 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
            {item.icon ? (
              <Fragment set:html={item.icon} />
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            )}
          </div>
          <h3 class="text-xl font-nunito font-bold text-primary mb-3">
            {item.title}
          </h3>
          <p class="text-text/70 leading-relaxed text-sm">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </Container>
</section>
