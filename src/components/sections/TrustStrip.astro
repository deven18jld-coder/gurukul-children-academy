---
import Container from '../ui/Container.astro';

interface TrustItem {
  title: string;
  subtitle?: string;
  icon?: string; // We'll just use a default checkmark if not provided to keep dependencies simple
}

interface Props {
  items: TrustItem[];
}

const { items } = Astro.props;
---

<section class="bg-primary py-8 border-b-4 border-accent relative z-20 shadow-lg">
  <Container>
    <div class="flex flex-wrap justify-center md:justify-between items-center gap-6 md:gap-4">
      {items.map((item) => (
        <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-xl border border-white/10 hover:bg-white/10 transition-colors duration-300 w-full sm:w-auto justify-center sm:justify-start">
          <div class="w-10 h-10 rounded-full bg-secondary/30 flex items-center justify-center text-accent flex-shrink-0">
            {item.icon ? (
              <Fragment set:html={item.icon} />
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            )}
          </div>
          <div>
            <div class="text-white font-nunito font-bold text-sm md:text-base leading-tight">
              {item.title}
            </div>
            {item.subtitle && (
              <div class="text-white/70 text-xs mt-0.5">
                {item.subtitle}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
