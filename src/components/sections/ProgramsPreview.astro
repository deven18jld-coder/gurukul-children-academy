---
import Container from '../ui/Container.astro';

interface Program {
  name: string;
  ageRange: string;
  description: string;
  href: string;
  colorTheme?: 'primary' | 'secondary' | 'accent';
}

interface Props {
  title?: string;
  subtitle?: string;
  programs: Program[];
}

const { 
  title = "Programs Designed for Every Stage", 
  subtitle = "From their first steps in a classroom to primary school confidence, we have the perfect environment for your child's growth.",
  programs 
} = Astro.props;

// Helper to determine badge background color based on theme
const getBadgeColor = (theme?: string) => {
  switch (theme) {
    case 'secondary': return 'bg-secondary/10 text-secondary';
    case 'accent': return 'bg-accent/15 text-accent';
    default: return 'bg-primary/10 text-primary';
  }
};
---

<section class="py-20 md:py-28 bg-soft-bg relative border-t border-white/50">
  <Container>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-nunito font-bold text-primary mb-4">
          {title}
        </h2>
        <p class="text-text/70 text-lg">
          {subtitle}
        </p>
      </div>
      <!-- Optional "View All" CTA could go here in the future -->
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
      {programs.map((program) => (
        <a href={program.href} class="bg-white rounded-3xl p-8 border border-white/40 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full group relative overflow-hidden">
          
          <div class={`absolute top-0 left-0 w-full h-1 ${program.colorTheme === 'secondary' ? 'bg-secondary' : program.colorTheme === 'accent' ? 'bg-accent' : 'bg-primary'}`}></div>

          <div class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-bold w-fit mb-6 ${getBadgeColor(program.colorTheme)}`}>
            Age {program.ageRange}
          </div>
          
          <h3 class="text-2xl font-nunito font-bold text-primary mb-3">
            {program.name}
          </h3>
          
          <p class="text-text/80 text-sm leading-relaxed mb-8 flex-grow">
            {program.description}
          </p>
          
          <div class="flex items-center text-primary font-bold text-sm mt-auto group-hover:text-secondary transition-colors">
            Learn More
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
