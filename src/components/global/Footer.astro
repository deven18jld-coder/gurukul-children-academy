---
import Container from '../ui/Container.astro';
import imageManifest from '../../generated/image-manifest.json';

const manifest = imageManifest as Record<string, any>;
const logoFiles = manifest?.logo?._files || [];
const logoSrc = logoFiles.length > 0 ? logoFiles[0].src : undefined;

const year = new Date().getFullYear();
---

<footer class="bg-primary text-white pt-16 pb-8">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <div>
        <div class="flex items-center space-x-2 mb-4 bg-white/5 p-2 rounded-xl inline-flex">
          {logoSrc ? (
            <img src={logoSrc} alt="School Logo" class="h-10 w-auto" />
          ) : (
            <>
              <div class="w-8 h-8 rounded bg-secondary flex items-center justify-center text-white font-bold">G</div>
              <span class="text-xl font-nunito font-bold">Gurukul Children Academy</span>
            </>
          )}
        </div>
        <p class="text-gray-300 text-sm max-w-sm">
          Where Every Child's Story Begins. Nurturing bright futures with a holistic and playful approach to learning.
        </p>
      </div>
      
      <div>
        <h3 class="font-nunito font-bold text-lg mb-4 text-accent">Quick Links</h3>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/programs" class="hover:text-white transition-colors">Our Programmes</a></li>
          <li><a href="/admissions" class="hover:text-white transition-colors">Admissions</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="font-nunito font-bold text-lg mb-4 text-accent">Contact Us</h3>
        <ul class="space-y-2 text-sm text-gray-300">
          <li>Belsar, Gonda</li>
          <li>Phone: +91 9838535987</li>
          <li>Email: gurukulchildrenacademy@gmail.com</li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between text-xs text-gray-400">
      <p>&copy; {year} Gurukul Children Academy. All rights reserved.</p>
      <div class="flex space-x-4 mt-4 md:mt-0">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </Container>
</footer>
