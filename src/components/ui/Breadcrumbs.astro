---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Generate breadcrumb items
const segments = currentPath.split('/').filter(Boolean);

let items = [{ name: 'Home', url: '/' }];
let accumulatedPath = '';

for (const segment of segments) {
  accumulatedPath += `/${segment}`;
  // Format the name: capitalize and remove dashes
  const name = segment
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
  
  items.push({ name, url: accumulatedPath });
}
---

<nav aria-label="Breadcrumb" class="py-4 border-b border-primary/5 bg-background/50">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8 xl:px-12">
    <ol class="flex flex-wrap items-center gap-2 text-sm font-medium">
      {items.map((item, index) => {
        const isLast = index === items.length - 1;
        return (
          <li class="flex items-center">
            {isLast ? (
              <span class="text-text/80 font-bold" aria-current="page">
                {item.name}
              </span>
            ) : (
              <a href={item.url} class="text-primary hover:text-secondary transition-colors">
                {item.name}
              </a>
            )}
            
            {!isLast && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-2 text-text/30">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            )}
          </li>
        );
      })}
    </ol>
  </div>
</nav>
